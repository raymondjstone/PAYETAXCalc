<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PAYETAXCalc.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PAYETAXCalc"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="UK PAYE Tax Calculator">

    <Window.SystemBackdrop>
        <MicaBackdrop/>
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar area - right padding leaves space for caption buttons -->
        <Grid x:Name="AppTitleBar" Height="48" Padding="16,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Image Source="Assets/AppSplash.png" Width="24" Height="24" VerticalAlignment="Center"/>
                <TextBlock Text="UK PAYE Tax Calculator" Style="{ThemeResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
            <HyperlinkButton x:Name="BuyMeCoffeeButton"
                             Content="☕ Buy me a coffee"
                             NavigateUri="https://buymeacoffee.com/raymondjstone"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Center"
                             Margin="0,0,148,0"
                             Padding="8,2"
                             FontSize="12"
                             ToolTipService.ToolTip="Any amount is appreciated and helps fund continued development!"
                             Click="BuyMeCoffeeButton_Click" />
        </Grid>

        <!-- TabView for tax years -->
        <TabView x:Name="TaxYearTabs" Grid.Row="1"
                 IsAddTabButtonVisible="True"
                 AddTabButtonClick="TaxYearTabs_AddTabButtonClick"
                 TabCloseRequested="TaxYearTabs_TabCloseRequested"
                 SelectionChanged="TaxYearTabs_SelectionChanged"
                 TabWidthMode="SizeToContent"
                 CanDragTabs="False"
                 CanReorderTabs="False">
            <TabView.TabStripHeader>
                <TextBlock Text="Tax Years:" VerticalAlignment="Center" Margin="12,0,0,0"
                           Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </TabView.TabStripHeader>
            <TabView.TabStripFooter>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="ImportButton" Click="Import_Click" VerticalAlignment="Center" Margin="0,0,4,0"
                            ToolTipService.ToolTip="Import data from a backup file (replaces current data)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8B5;" FontSize="14"/>
                            <TextBlock Text="Import"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BackupButton" Click="Backup_Click" VerticalAlignment="Center" Margin="0,0,4,0"
                            ToolTipService.ToolTip="Export a backup copy of all data to a file">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE896;" FontSize="14"/>
                            <TextBlock Text="Backup"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SaveButton" Click="Save_Click" VerticalAlignment="Center" Margin="0,0,8,0"
                            ToolTipService.ToolTip="Save all data">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                            <TextBlock Text="Save"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </TabView.TabStripFooter>
        </TabView>
    </Grid>
</Window>
