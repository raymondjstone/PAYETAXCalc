<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PAYETAXCalc.Controls.TaxYearTabContent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PAYETAXCalc.Controls"
    xmlns:converters="using:PAYETAXCalc.Converters"
    xmlns:nf="using:Windows.Globalization.NumberFormatting"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:CurrencyConverter x:Key="CurrencyFmt"/>
        <converters:OverUnderPaymentConverter x:Key="OverUnderFmt"/>

        <nf:DecimalFormatter x:Key="CurrencyFormatter"
                             FractionDigits="2"
                             IntegerDigits="1"
                             IsGrouped="True"/>

        <nf:DecimalFormatter x:Key="WholeNumberFormatter"
                             FractionDigits="0"
                             IntegerDigits="1"
                             IsGrouped="True"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16,24,24">
        <StackPanel Spacing="16" MaxWidth="900">

            <!-- Tax Rules Info -->
            <InfoBar x:Name="RulesInfoBar"
                     IsOpen="True" IsClosable="False"
                     Severity="Informational"
                     Title="Tax Rules"/>

            <!-- ═══════════ EMPLOYMENTS ═══════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Employments &amp; Pensions" Style="{ThemeResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Click="AddEmployment_Click" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="Add Employment / Pension"/>
                    </StackPanel>
                </Button>
            </Grid>

            <ItemsControl x:Name="EmploymentsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="16" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <StackPanel Spacing="4">

                                <!-- Header: Name, PAYE Ref, Remove -->
                                <Grid ColumnDefinitions="*,*,Auto">
                                    <TextBox Header="Employer / Pension Provider" Text="{Binding EmployerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,8,8" MinWidth="200"/>
                                    <TextBox Grid.Column="1" Header="PAYE Reference" Text="{Binding PayeReference, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,8,8"/>
                                    <Button Grid.Column="2" VerticalAlignment="Top" Margin="0,20,0,0"
                                            Click="RemoveEmployment_Click" ToolTipService.ToolTip="Remove">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                    </Button>
                                </Grid>


                                <!-- Pension/Annuity toggle -->
                                <CheckBox Content="This is a pension or annuity (not active employment)"
                                          IsChecked="{Binding IsPensionOrAnnuity, Mode=TwoWay}"
                                          Margin="0,0,0,0"/>
                                <TextBlock Text="Pension payments do not pay National Insurance."
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Margin="0,0,0,4"
                                           Visibility="{Binding IsPensionOrAnnuity, Converter={StaticResource BoolToVis}}"/>

                                <!-- Combined Tax & NI option (active employment only) -->
                                <CheckBox Content="I only have combined Tax &amp; NI figures"
                                          IsChecked="{Binding IsCombinedTaxAndNI, Mode=TwoWay}"
                                          Visibility="{Binding IsPensionOrAnnuity, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                          Margin="0,0,0,4"/>
                                <TextBlock Text="NI will be estimated from your salary and deducted from the combined figure"
                                           Visibility="{Binding IsCombinedTaxAndNI, Converter={StaticResource BoolToVis}}"
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                           Style="{ThemeResource CaptionTextBlockStyle}" Margin="0,0,0,4"/>

                                <!-- Income: Salary/Pension, Tax Paid -->
                                <Grid ColumnDefinitions="*,*,Auto">
                                    <NumberBox Header="Gross Income (£)"
                                               Value="{Binding GrossSalary, Mode=TwoWay}"
                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                               SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                               Margin="0,0,8,8" Minimum="0"/>
                                    <NumberBox Grid.Column="1" Header="Tax &amp; NI Paid (£)"
                                               Value="{Binding TaxPaid, Mode=TwoWay}"
                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                               SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                               Margin="0,0,8,8" Minimum="0"
                                               Visibility="{Binding IsCombinedTaxAndNI, Converter={StaticResource BoolToVis}}"/>
                                    <NumberBox Grid.Column="1" Header="Tax Paid (£)"
                                               Value="{Binding TaxPaid, Mode=TwoWay}"
                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                               SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                               Margin="0,0,8,8" Minimum="0"
                                               Visibility="{Binding IsCombinedTaxAndNI, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                                </Grid>

                                <!-- Active employment fields (hidden for pension/annuity) -->
                                <StackPanel Visibility="{Binding IsPensionOrAnnuity, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"
                                            Spacing="4">

                                    <!-- NI, BIK -->
                                    <Grid ColumnDefinitions="*,*,Auto">
                                        <NumberBox Header="NI Paid (£)"
                                                   Value="{Binding NationalInsurancePaid, Mode=TwoWay}"
                                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                                   Margin="0,0,8,8" Minimum="0"
                                                   Visibility="{Binding IsCombinedTaxAndNI, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                                        <NumberBox Grid.Column="1" Header="Benefits in Kind (£)"
                                                   Value="{Binding BenefitsInKind, Mode=TwoWay}"
                                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                                   Margin="0,0,8,8" Minimum="0"/>
                                    </Grid>

                                    <!-- Pension Contributions -->
                                    <Grid ColumnDefinitions="*,*,Auto">
                                        <NumberBox Header="Pension Contributions (£)"
                                                   Value="{Binding PensionContributions, Mode=TwoWay}"
                                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                                   Margin="0,0,8,8" Minimum="0"/>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="0,16,0,0"
                                                   Text="Workplace pension contributions (Net Pay/AVC) - get full tax relief via PAYE"
                                                   TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    </Grid>

                                    <!-- Company Car Section -->
                                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                              Margin="0,4,0,0" Padding="0">
                                        <Expander.Header>
                                            <TextBlock Text="Company Car"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                        </Expander.Header>
                                        <Expander.Content>
                                            <StackPanel Spacing="4" Padding="0,8,0,4">
                                                <CheckBox Content="I have a company car from this employer"
                                                          IsChecked="{Binding HasCompanyCar, Mode=TwoWay}"/>
                                                <StackPanel Visibility="{Binding HasCompanyCar, Converter={StaticResource BoolToVis}}" Spacing="4">
                                                    <Grid ColumnDefinitions="*,*">
                                                        <NumberBox Header="Car List Price (P11D value) (£)"
                                                                   Value="{Binding CarListPrice, Mode=TwoWay}"
                                                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                                                   SpinButtonPlacementMode="Compact" SmallChange="1000" LargeChange="5000"
                                                                   Margin="0,0,8,8" Minimum="0"/>
                                                        <NumberBox Grid.Column="1" Header="CO2 Emissions (g/km)"
                                                                   Value="{Binding CarCO2Emissions, Mode=TwoWay}"
                                                                   NumberFormatter="{StaticResource WholeNumberFormatter}"
                                                                   SpinButtonPlacementMode="Compact" SmallChange="1" LargeChange="10"
                                                                   Margin="0,0,0,8" Minimum="0"/>
                                                    </Grid>
                                                    <CheckBox Content="Electric/Zero emissions vehicle"
                                                              IsChecked="{Binding CarIsElectric, Mode=TwoWay}"/>
                                                    <NumberBox Header="Employer-provided fuel benefit (enter 1 if yes, 0 if no)"
                                                               Value="{Binding CarFuelBenefit, Mode=TwoWay}"
                                                               NumberFormatter="{StaticResource WholeNumberFormatter}"
                                                               SpinButtonPlacementMode="Compact" SmallChange="1" LargeChange="1"
                                                               Minimum="0" Maximum="1" MaxWidth="300" HorizontalAlignment="Left"
                                                               Margin="0,0,0,8"/>
                                                    <TextBlock Text="BIK percentage is calculated from CO2 emissions. The benefit value is added to your taxable income automatically."
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Expander.Content>
                                    </Expander>

                                    <!-- Allowable Expenses Section -->
                                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                              Margin="0,4,0,0" Padding="0">
                                        <Expander.Header>
                                            <TextBlock Text="Allowable Expenses (WFH, mileage, subscriptions, etc.)"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                        </Expander.Header>
                                        <Expander.Content>
                                            <StackPanel Spacing="4" Padding="0,8,0,4">
                                                <Grid ColumnDefinitions="*,*">
                                                    <NumberBox Header="Working from Home (weeks)"
                                                               Value="{Binding WorkFromHomeWeeks, Mode=TwoWay}"
                                                               NumberFormatter="{StaticResource WholeNumberFormatter}"
                                                               SpinButtonPlacementMode="Compact" SmallChange="1" LargeChange="4"
                                                               Margin="0,0,8,8" Minimum="0" Maximum="52"
                                                               PlaceholderText="HMRC flat rate per week"/>
                                                    <NumberBox Grid.Column="1" Header="Business Miles (total)"
                                                               Value="{Binding BusinessMiles, Mode=TwoWay}"
                                                               NumberFormatter="{StaticResource WholeNumberFormatter}"
                                                               SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                                               Margin="0,0,0,8" Minimum="0"
                                                               PlaceholderText="AMAP rate applied automatically"/>
                                                </Grid>
                                                <TextBlock Text="WFH: £6/week flat rate. Mileage: 45p/mile first 10,000, 25p/mile thereafter."
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                                                           Margin="0,0,0,8"/>

                                                <Grid ColumnDefinitions="*,*">
                                                    <NumberBox Header="Professional Subscriptions (£)"
                                                               Value="{Binding ProfessionalSubscriptions, Mode=TwoWay}"
                                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                                               SpinButtonPlacementMode="Compact" SmallChange="10" LargeChange="50"
                                                               Margin="0,0,8,8" Minimum="0"
                                                               PlaceholderText="HMRC-approved bodies only"/>
                                                    <NumberBox Grid.Column="1" Header="Uniform/Work Clothing (£)"
                                                               Value="{Binding UniformAllowance, Mode=TwoWay}"
                                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                                               SpinButtonPlacementMode="Compact" SmallChange="10" LargeChange="50"
                                                               Margin="0,0,0,8" Minimum="0"
                                                               PlaceholderText="Flat rate or actual cost"/>
                                                </Grid>
                                                <TextBlock Text="Professional subs: fees to HMRC-approved professional bodies. Uniform: £60 flat rate for laundering, or actual cost if higher."
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                                                           Margin="0,0,0,8"/>

                                                <Grid ColumnDefinitions="*,*">
                                                    <NumberBox Header="Other Allowable Expenses (£)"
                                                               Value="{Binding OtherExpenses, Mode=TwoWay}"
                                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                                               SpinButtonPlacementMode="Compact" SmallChange="10" LargeChange="100"
                                                               Margin="0,0,8,8" Minimum="0"/>
                                                    <TextBox Grid.Column="1" Header="Description"
                                                             Text="{Binding OtherExpensesDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,0,8"
                                                             PlaceholderText="e.g. tools, equipment"/>
                                                </Grid>
                                            </StackPanel>
                                        </Expander.Content>
                                    </Expander>
                                </StackPanel>

                                <!-- Ended (always visible) -->
                                <CheckBox Content="This income source ended in this tax year"
                                          IsChecked="{Binding EmploymentEnded, Mode=TwoWay}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════════ SAVINGS INTEREST ═══════════ -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Savings Interest" Style="{ThemeResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Click="AddSavings_Click" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="Add Savings Account"/>
                    </StackPanel>
                </Button>
            </Grid>

            <ItemsControl x:Name="SavingsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="16" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,Auto">
                                <TextBox Header="Provider / Account Name"
                                         Text="{Binding ProviderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,8" MinWidth="200"/>
                                <NumberBox Grid.Column="1" Header="Interest Earned (£)"
                                           Value="{Binding InterestAmount, Mode=TwoWay}"
                                           NumberFormatter="{StaticResource CurrencyFormatter}"
                                           SpinButtonPlacementMode="Compact" SmallChange="10" LargeChange="100"
                                           Margin="0,0,8,8" Minimum="0"/>
                                <Button Grid.Column="2" VerticalAlignment="Top" Margin="0,20,0,0"
                                        Click="RemoveSavings_Click" ToolTipService.ToolTip="Remove savings account">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Button>
                                <CheckBox Grid.Row="1" Grid.ColumnSpan="2"
                                          Content="Tax Free (Cash ISA / Stocks &amp; Shares ISA)"
                                          IsChecked="{Binding IsTaxFree, Mode=TwoWay}" Margin="0,4,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════════ DIVIDENDS ═══════════ -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Dividend Income" Style="{ThemeResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Click="AddDividend_Click" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="Add Dividend Source"/>
                    </StackPanel>
                </Button>
            </Grid>

            <ItemsControl x:Name="DividendsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="16" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid ColumnDefinitions="*,*,*,Auto">
                                <TextBox Header="Company / Fund Name"
                                         Text="{Binding CompanyName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,0" MinWidth="160"/>
                                <NumberBox Grid.Column="1" Header="Gross Dividend (£)"
                                           Value="{Binding GrossDividend, Mode=TwoWay}"
                                           NumberFormatter="{StaticResource CurrencyFormatter}"
                                           SpinButtonPlacementMode="Compact" SmallChange="10" LargeChange="100"
                                           Margin="0,0,8,0" Minimum="0"/>
                                <NumberBox Grid.Column="2" Header="Tax Paid / Withheld (£)"
                                           Value="{Binding TaxPaid, Mode=TwoWay}"
                                           NumberFormatter="{StaticResource CurrencyFormatter}"
                                           SpinButtonPlacementMode="Compact" SmallChange="10" LargeChange="100"
                                           Margin="0,0,8,0" Minimum="0"/>
                                <Button Grid.Column="3" VerticalAlignment="Top" Margin="0,20,0,0"
                                        Click="RemoveDividend_Click" ToolTipService.ToolTip="Remove dividend source">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════════ CAPITAL GAINS ═══════════ -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Capital Gains" Style="{ThemeResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Click="AddCapitalGain_Click" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                        <TextBlock Text="Add Capital Gain"/>
                    </StackPanel>
                </Button>
            </Grid>

            <ItemsControl x:Name="CapitalGainsPanel">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="16" CornerRadius="8"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,Auto">
                                <TextBox Header="Description (asset sold)"
                                         Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,0,8,8" MinWidth="200"/>
                                <NumberBox Grid.Column="1" Header="Gain Amount (£)"
                                           Value="{Binding GainAmount, Mode=TwoWay}"
                                           NumberFormatter="{StaticResource CurrencyFormatter}"
                                           SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                           Margin="0,0,8,8" Minimum="0"/>
                                <Button Grid.Column="2" VerticalAlignment="Top" Margin="0,20,0,0"
                                        Click="RemoveCapitalGain_Click" ToolTipService.ToolTip="Remove">
                                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                                </Button>
                                <CheckBox Grid.Row="1" Grid.ColumnSpan="2"
                                          Content="Residential property disposal"
                                          IsChecked="{Binding IsResidentialProperty, Mode=TwoWay}" Margin="0,4,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border x:Name="CapitalGainsLossesPanel" Padding="16" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    Visibility="Collapsed">
                <NumberBox x:Name="CapitalGainsLossesBox" Header="Capital Losses to Offset (£)"
                           NumberFormatter="{StaticResource CurrencyFormatter}"
                           SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                           Minimum="0" MaxWidth="300" HorizontalAlignment="Left"/>
            </Border>

            <!-- ═══════════ RENTAL / PROPERTY INCOME ═══════════ -->
            <TextBlock Text="Rental / Property Income" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>
            <Border Padding="16" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,*">
                        <NumberBox x:Name="RentalIncomeBox" Header="Gross Rental Income (£)"
                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                   Margin="0,0,8,0" Minimum="0"/>
                        <NumberBox x:Name="RentalExpensesBox" Grid.Column="1" Header="Allowable Expenses (£)"
                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                   Minimum="0"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,*">
                        <NumberBox x:Name="MortgageInterestBox" Header="Mortgage Interest (£)"
                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                   Margin="0,0,8,0" Minimum="0"/>
                        <CheckBox x:Name="UsePropertyAllowanceCheck" Grid.Column="1"
                                  Content="Use £1,000 Property Allowance instead of expenses"
                                  VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="Mortgage interest gets 20% basic rate tax credit (not deducted from income). Property allowance: if income is under £1,000, use the allowance instead of claiming expenses."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══════════ TRADING INCOME ═══════════ -->
            <TextBlock Text="Trading / Self-Employment Income" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>
            <Border Padding="16" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,*">
                        <NumberBox x:Name="TradingIncomeBox" Header="Gross Trading Income (£)"
                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                   Margin="0,0,8,0" Minimum="0"/>
                        <NumberBox x:Name="TradingExpensesBox" Grid.Column="1" Header="Trading Expenses (£)"
                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                                   Minimum="0"/>
                    </Grid>
                    <CheckBox x:Name="UseTradingAllowanceCheck"
                              Content="Use £1,000 Trading Allowance instead of expenses"/>
                    <TextBlock Text="For casual self-employment, eBay/marketplace selling, freelance work. If income is under £1,000, the trading allowance covers it entirely."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══════════ OTHER DETAILS ═══════════ -->
            <TextBlock Text="Other Details" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,8,0,0"/>
            <Border Padding="16" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <!-- Tax Code -->
                    <Grid ColumnDefinitions="*,*">
                        <TextBox x:Name="TaxCodeBox" Header="PAYE Tax Code (e.g. 1257L, S1257L, K497, BR)"
                                 PlaceholderText="Enter your tax code to validate it"
                                 Margin="0,0,8,0"/>
                        <NumberBox x:Name="PriorYearTaxBox" Grid.Column="1"
                                   Header="Prior Year Tax Collected via PAYE (£)"
                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                   SpinButtonPlacementMode="Compact" SmallChange="50" LargeChange="500"
                                   Minimum="0" PlaceholderText="Tax owed from previous year"/>
                    </Grid>
                    <TextBlock Text="If HMRC is collecting underpaid tax from a previous year through your tax code, enter the amount here. This is usually shown on your P2 coding notice. It will be subtracted from your PAYE payments when calculating this year's over/underpayment."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                    <!-- Student Loans -->
                    <TextBlock Text="Student Loans" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <CheckBox x:Name="HasStudentLoanCheck" Content="I have a student loan"/>
                    <StackPanel x:Name="StudentLoanPlanPanel" Visibility="Collapsed" Spacing="4" Margin="24,0,0,0">
                        <RadioButtons x:Name="StudentLoanPlanRadios" Header="Student Loan Plan">
                            <RadioButton x:Name="SLPlan1" Content="Plan 1 (started before Sept 2012, or NI/Scotland)"/>
                            <RadioButton x:Name="SLPlan2" Content="Plan 2 (started Sept 2012 onwards, England/Wales)"/>
                            <RadioButton x:Name="SLPlan4" Content="Plan 4 (Scotland, from Apr 2021)"/>
                            <RadioButton x:Name="SLPlan5" Content="Plan 5 (started Sept 2023 onwards)"/>
                        </RadioButtons>
                    </StackPanel>
                    <CheckBox x:Name="HasPostgraduateLoanCheck" Content="I have a postgraduate loan"/>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                    <!-- Child Benefit / HICBC -->
                    <TextBlock Text="Child Benefit" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <Grid ColumnDefinitions="*,*">
                        <NumberBox x:Name="NumberOfChildrenBox" Header="Number of Children"
                                   NumberFormatter="{StaticResource WholeNumberFormatter}"
                                   SpinButtonPlacementMode="Compact" SmallChange="1" LargeChange="1"
                                   Margin="0,0,8,0" Minimum="0" Maximum="20"/>
                        <NumberBox x:Name="ChildBenefitAmountBox" Grid.Column="1" Header="Annual Child Benefit Received (£)"
                                   NumberFormatter="{StaticResource CurrencyFormatter}"
                                   SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="500"
                                   Minimum="0" PlaceholderText="Leave 0 to auto-calculate"/>
                    </Grid>
                    <TextBlock Text="If income exceeds £60,000 (2024/25+) or £50,000 (2023/24), you may owe the High Income Child Benefit Charge. Leave amount at 0 to use standard weekly rates."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,4"/>

                    <CheckBox x:Name="MarriageAllowanceCheck" Content="Claim Marriage Allowance"
                              IsChecked="{Binding ClaimMarriageAllowance, Mode=TwoWay}" Checked="MarriageAllowance_Changed" Unchecked="MarriageAllowance_Changed"/>
                    <RadioButtons x:Name="MarriageDirectionPanel" Header="Marriage Allowance Direction"
                                  Visibility="{Binding ClaimMarriageAllowance, Converter={StaticResource BoolToVis}}">
                        <RadioButton x:Name="MAReceiver" Content="I am receiving the allowance transfer (my spouse earns less)"/>
                        <RadioButton x:Name="MATransferrer" Content="I am transferring my allowance to my spouse"/>
                    </RadioButtons>

                    <CheckBox x:Name="BlindPersonCheck" Content="Claim Blind Person's Allowance"
                              IsChecked="{Binding ClaimBlindPersonsAllowance, Mode=TwoWay}"/>

                    <CheckBox x:Name="ScottishTaxpayerCheck" Content="Scottish Taxpayer (use Scottish income tax rates)"
                              IsChecked="{Binding IsScottishTaxpayer, Mode=TwoWay}"
                              Checked="ScottishTaxpayerCheck_Checked"/>

                    <CheckBox x:Name="WelshTaxpayerCheck" Content="Welsh Taxpayer (use Welsh income tax rates)"
                              IsChecked="{Binding IsWelshTaxpayer, Mode=TwoWay}"
                              Checked="WelshTaxpayerCheck_Checked"/>

                    <NumberBox x:Name="GiftAidBox" Header="Gift Aid Donations in this tax year (£)"
                               Value="{Binding GiftAidDonations, Mode=TwoWay}"
                               NumberFormatter="{StaticResource CurrencyFormatter}"
                               SpinButtonPlacementMode="Compact" SmallChange="10" LargeChange="100"
                               Minimum="0" MaxWidth="300" HorizontalAlignment="Left"/>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8,0,8"/>

                    <!-- Investment Reliefs -->
                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                        <Expander.Header>
                            <TextBlock Text="Investment Tax Reliefs (EIS / SEIS / VCT)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                        </Expander.Header>
                        <Expander.Content>
                            <StackPanel Spacing="8" Padding="0,8,0,4">
                                <Grid ColumnDefinitions="*,*,*">
                                    <NumberBox x:Name="EisBox" Header="EIS Investment (£)"
                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                               SpinButtonPlacementMode="Compact" SmallChange="1000" LargeChange="5000"
                                               Margin="0,0,8,0" Minimum="0"/>
                                    <NumberBox x:Name="SeisBox" Grid.Column="1" Header="SEIS Investment (£)"
                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                               SpinButtonPlacementMode="Compact" SmallChange="1000" LargeChange="5000"
                                               Margin="0,0,8,0" Minimum="0"/>
                                    <NumberBox x:Name="VctBox" Grid.Column="2" Header="VCT Investment (£)"
                                               NumberFormatter="{StaticResource CurrencyFormatter}"
                                               SpinButtonPlacementMode="Compact" SmallChange="1000" LargeChange="5000"
                                               Minimum="0"/>
                                </Grid>
                                <TextBlock Text="EIS: 30% relief. SEIS: 50% relief. VCT: 30% relief. Deducted from income tax liability. Shares must be held for minimum period."
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Expander.Content>
                    </Expander>

                    <!-- Pension Tax Credit Section -->
                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8,0,8"/>
                    <TextBlock Text="Personal Pension Tax Credit" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                    <TextBlock Text="Different from workplace pensions above! This is for personal pensions (SIPPs, stakeholder pensions) paid from your bank account."
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                               Margin="0,4,0,8"/>
                    <NumberBox x:Name="ReliefAtSourceBox" Header="Personal Pension Contributions - Net Amount Paid (£)"
                               Value="{Binding ReliefAtSourcePensionContributions, Mode=TwoWay}"
                               NumberFormatter="{StaticResource CurrencyFormatter}"
                               SpinButtonPlacementMode="Compact" SmallChange="100" LargeChange="1000"
                               Minimum="0" MaxWidth="300" HorizontalAlignment="Left"
                               PlaceholderText="Amount you paid from your bank account"/>
                    <TextBlock TextWrapping="Wrap" Margin="0,4,0,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}">
                        <Run Text="Enter the amount YOU paid into personal pensions (the amount that left your bank account)."/><LineBreak/>
                        <Run Text="Your pension provider already adds 20% basic rate relief automatically"/><LineBreak/>
                        <Run Text="Higher rate (40%) and additional rate (45%) taxpayers can claim back extra relief"/><LineBreak/>
                        <Run Text="Do NOT include workplace pension contributions (enter those above under each employment)"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ═══════════ CALCULATE ═══════════ -->
            <Button Click="Calculate_Click" Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch" Height="44" Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE9D9;" FontSize="16"/>
                    <TextBlock Text="Calculate Tax Liability" FontSize="15" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <!-- ═══════════ RESULTS ═══════════ -->
            <Border x:Name="ResultsPanel" Visibility="Collapsed"
                    Padding="20" CornerRadius="8" Margin="0,4,0,0"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" BorderThickness="2">
                <StackPanel Spacing="6">
                    <TextBlock Text="Tax Calculation Summary" Style="{ThemeResource SubtitleTextBlockStyle}" Margin="0,0,0,8"/>

                    <!-- Income Summary -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Total Employment/Pension Income:"/>
                        <TextBlock x:Name="ResEmploymentIncome" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Total Benefits in Kind:"/>
                        <TextBlock x:Name="ResBIK" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid x:Name="ResCompanyCarRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="  (incl. Company Car BIK):" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="ResCompanyCar" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                    <Grid x:Name="ResPensionRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Pension Contributions (tax relief):"/>
                        <TextBlock x:Name="ResPension" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid x:Name="ResExpensesRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Allowable Employment Expenses:"/>
                        <TextBlock x:Name="ResExpenses" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>
                    <TextBlock x:Name="ResExpensesBreakdown" Visibility="Collapsed"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" Margin="12,0,0,0"/>
                    <Grid x:Name="ResRentalRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Rental/Property Income (taxable):"/>
                        <TextBlock x:Name="ResRental" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid x:Name="ResTradingRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Trading Income (taxable):"/>
                        <TextBlock x:Name="ResTrading" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Taxable Savings Interest:"/>
                        <TextBlock x:Name="ResSavings" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto" Visibility="{Binding TotalTaxFreeSavings, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                        <TextBlock Text="Tax-Free Savings (ISA):" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                        <TextBlock x:Name="ResTaxFreeSavings" Grid.Column="1" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                    </Grid>
                    <Grid x:Name="ResDividendRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Dividend Income:"/>
                        <TextBlock x:Name="ResDividends" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Gross Taxable Income:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ResGross" Grid.Column="1" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Personal Allowance Used:"/>
                        <TextBlock x:Name="ResPA" Grid.Column="1"/>
                    </Grid>
                    <Grid x:Name="ResGiftAidRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Gift Aid Band Extension:"/>
                        <TextBlock x:Name="ResGiftAid" Grid.Column="1"/>
                    </Grid>
                    <Grid x:Name="ResMarriageRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Marriage Allowance Credit:"/>
                        <TextBlock x:Name="ResMarriage" Grid.Column="1"/>
                    </Grid>
                    <Grid x:Name="ResMortgageReliefRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Mortgage Interest Relief (20% credit):"/>
                        <TextBlock x:Name="ResMortgageRelief" Grid.Column="1" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                    </Grid>
                    <Grid x:Name="ResInvestmentReliefRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Investment Relief (EIS/SEIS/VCT):"/>
                        <TextBlock x:Name="ResInvestmentRelief" Grid.Column="1" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6"/>

                    <!-- Tax Breakdown -->
                    <TextBlock x:Name="ResTaxBreakdownHeader" Text="Income Tax Breakdown" FontWeight="SemiBold" Margin="0,4,0,4"/>
                    <ItemsControl x:Name="TaxBreakdownItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,2">
                                    <TextBlock Text="{Binding Label}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding IncomeText}" Margin="0,0,20,0"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TaxText}" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,6"/>

                    <!-- Step 1: Income Tax from bands -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Income Tax Due:" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="ResTotalTaxDue" Grid.Column="1" FontSize="16" FontWeight="Bold"/>
                    </Grid>

                    <!-- Step 2: Prior year tax added (if applicable) -->
                    <Grid x:Name="ResPriorYearTaxRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Plus: Prior Year Tax Collected via PAYE:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="ResPriorYearTax" Grid.Column="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>

                    <!-- Step 3: Total income tax due (inc. prior year) -->
                    <Grid x:Name="ResEffectiveTaxPaidRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Total Income Tax Due (inc. prior year):" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ResEffectiveTaxPaid" Grid.Column="1" FontSize="16" FontWeight="SemiBold"/>
                    </Grid>

                    <!-- Step 4: Less tax already paid via PAYE -->
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Less: Total Tax Paid (PAYE):" FontSize="16"/>
                        <TextBlock x:Name="ResTotalTaxPaid" Grid.Column="1" FontSize="16"/>
                    </Grid>

                    <!-- Step 5: Capital Gains Tax -->
                    <Border x:Name="ResCGTSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResCGTPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Plus: Capital Gains Tax" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="CGT Due:"/>
                            <TextBlock x:Name="ResCGT" Grid.Column="1" FontWeight="SemiBold"/>
                        </Grid>
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="View CGT Breakdown" Style="{ThemeResource BodyTextBlockStyle}"/>
                            </Expander.Header>
                            <Expander.Content>
                                <TextBlock x:Name="ResCGTInfo" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{ThemeResource BodyTextBlockStyle}" Padding="0,8"/>
                            </Expander.Content>
                        </Expander>
                    </StackPanel>

                    <!-- Combined label (Income + CGT) shown when CGT applies -->
                    <Grid x:Name="ResTotalCombinedRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                        <TextBlock Text="Income and Capital Gains Tax due:" FontSize="16" FontWeight="Bold"/>
                        <TextBlock x:Name="ResTotalCombinedTaxDue" Grid.Column="1" FontSize="16" FontWeight="Bold"/>
                    </Grid>

                    <!-- Step 6: Final total -->
                    <Border Height="2" Background="{ThemeResource AccentFillColorDefaultBrush}" Margin="0,8"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="ResOverUnderLabel" Text="Total Due / Overpaid:" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="ResOverUnder" Grid.Column="1" FontSize="18" FontWeight="Bold"/>
                    </Grid>

                    <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8"/>

                    <!-- NI Summary -->
                    <TextBlock Text="National Insurance" FontWeight="SemiBold" Margin="0,4,0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Total NI Paid:"/>
                        <TextBlock x:Name="ResNIPaid" Grid.Column="1"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="Expected NI:"/>
                        <TextBlock x:Name="ResExpectedNI" Grid.Column="1"/>
                    </Grid>
                    <TextBlock x:Name="ResNIEstimationInfo" TextWrapping="Wrap"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" Margin="0,4,0,0"
                               Visibility="Collapsed"/>

                    <!-- Student Loan Section -->
                    <Border x:Name="ResStudentLoanSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResStudentLoanPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Student Loan Repayments" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Annual Repayment:"/>
                            <TextBlock x:Name="ResStudentLoan" Grid.Column="1" FontWeight="SemiBold"/>
                        </Grid>
                        <TextBlock x:Name="ResStudentLoanInfo" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Child Benefit Charge Section -->
                    <Border x:Name="ResChildBenefitSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResChildBenefitPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="High Income Child Benefit Charge" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="HICBC Charge:"/>
                            <TextBlock x:Name="ResChildBenefit" Grid.Column="1" FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        </Grid>
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="View Details" Style="{ThemeResource BodyTextBlockStyle}"/>
                            </Expander.Header>
                            <Expander.Content>
                                <TextBlock x:Name="ResChildBenefitInfo" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{ThemeResource BodyTextBlockStyle}" Padding="0,8"/>
                            </Expander.Content>
                        </Expander>
                    </StackPanel>



                    <!-- Pension Annual Allowance Charge Section -->
                    <Border x:Name="ResPensionAACSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResPensionAACPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Pension Annual Allowance Charge" FontWeight="SemiBold" Margin="0,4,0,4"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="AAC Charge:"/>
                            <TextBlock x:Name="ResPensionAAC" Grid.Column="1" FontWeight="SemiBold"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        </Grid>
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="View Details" Style="{ThemeResource BodyTextBlockStyle}"/>
                            </Expander.Header>
                            <Expander.Content>
                                <TextBlock x:Name="ResPensionAACInfo" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{ThemeResource BodyTextBlockStyle}" Padding="0,8"/>
                            </Expander.Content>
                        </Expander>
                    </StackPanel>

                    <!-- Tax Code Validation Section -->
                    <Border x:Name="ResTaxCodeSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResTaxCodePanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Tax Code Validation" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <TextBlock x:Name="ResTaxCodeInfo" TextWrapping="Wrap"
                                   Style="{ThemeResource BodyTextBlockStyle}"/>
                    </StackPanel>

                    <!-- Pension Tax Credit Section -->
                    <Border x:Name="ResPensionTaxCreditSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResPensionTaxCreditPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Pension Tax Credit" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Relief at Source Contributions:"/>
                            <TextBlock x:Name="ResReliefAtSource" Grid.Column="1"/>
                        </Grid>
                        <Grid x:Name="ResPensionCreditRow" ColumnDefinitions="*,Auto" Visibility="Collapsed">
                            <TextBlock Text="Additional Tax Relief Claimable:" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ResPensionCredit" Grid.Column="1" Foreground="{ThemeResource SystemFillColorSuccessBrush}" FontWeight="SemiBold"/>
                        </Grid>
                        <Expander x:Name="ResPensionCreditExpander" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Margin="0,4,0,0">
                            <Expander.Header>
                                <TextBlock Text="View Details &amp; How to Claim" Style="{ThemeResource BodyTextBlockStyle}"/>
                            </Expander.Header>
                            <Expander.Content>
                                <TextBlock x:Name="ResPensionCreditInfo" TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{ThemeResource BodyTextBlockStyle}" Padding="0,8"/>
                            </Expander.Content>
                        </Expander>
                    </StackPanel>

                    <!-- Company Car Details -->
                    <Border x:Name="ResCompanyCarSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResCompanyCarPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Company Car Benefit Details" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <TextBlock x:Name="ResCompanyCarInfo" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource BodyTextBlockStyle}"/>
                    </StackPanel>

                    <!-- Investment Relief Details -->
                    <Border x:Name="ResInvestmentSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResInvestmentPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Investment Relief Details" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <TextBlock x:Name="ResInvestmentInfo" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource BodyTextBlockStyle}"/>
                    </StackPanel>

                    <!-- Rental Income Details -->
                    <Border x:Name="ResRentalSection" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" Margin="0,8" Visibility="Collapsed"/>
                    <StackPanel x:Name="ResRentalPanel" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Rental Income Details" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <TextBlock x:Name="ResRentalInfo" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource BodyTextBlockStyle}"/>
                    </StackPanel>

                    <!-- Summary -->
                    <InfoBar x:Name="ResultInfoBar" IsOpen="True" IsClosable="False" Margin="0,12,0,0"/>

                    <!-- Export buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                        <TextBlock Text="Export:" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <Button Click="ExportExcel_Click" ToolTipService.ToolTip="Export to Excel (.xlsx)">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE9F9;" FontSize="14"/>
                                <TextBlock Text="Excel"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ExportPdf_Click" ToolTipService.ToolTip="Export to PDF (.pdf)">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xEA90;" FontSize="14"/>
                                <TextBlock Text="PDF"/>
                            </StackPanel>
                        </Button>
                        <Button Click="ExportWord_Click" ToolTipService.ToolTip="Export to Word (.docx)">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8A5;" FontSize="14"/>
                                <TextBlock Text="Word"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Bottom spacing -->
            <Border Height="24"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
